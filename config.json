{
  "settings": {
    "log_file_path": "./proxy.log",
    "seconds_between_each_check": 300
  },

  "global_firewall": {
    "enabled": true,
    "options": {
      "blacklisting": {
        "blacklist_ip": {
          "enabled": false,
          "block_list": []
        },
        "blacklisted_ranges": {
          "enabled": false,
          "block_list": []
        }
      },
      "whitelisting": {
        "whitelist_ip": {
          "enabled": false,
          "allow_list": []
        },
        "whitelist_range": {
          "enabled": false,
          "allow_list": []
        }
      }
    }
  },

  "discord_settings": {
    "enabled": true,
    "username": "AURA Proxy",
    "avatar_url": "https://example.com/avatar.png"
  },

  "proxied_hosts": [
    {
      "proxy_enabled": false,
      "proxy_port": 100,
      "backend_ip": "127.0.0.1",
      "backend_port": 2222,
      "discord_webhook_url": "",
      "expiry": {
        "does_expire": false,
        "expiry_date": "9999-01-20",
        "optional_note": "yyyy-mm-dd"
      }
    },
  
    {
      "proxy_enabled": false,
      "proxy_port": 1337,
      "backend_ip": "8.8.8.8",
      "backend_port": 1000,
      "discord_webhook_url": "",
      "expiry": {
        "does_expire": true,
        "expiry_date": "2026-02-30",
        "optional_note": "yyyy-mm-dd"
      }
    }
  ]
}
